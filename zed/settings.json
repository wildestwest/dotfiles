  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "on_yank",
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 600,
  },
  "auto_install_extensions": {
    "dockerfile": true,
    "fastapi-snippets": true,
    "markdown-snippets": true,
    "helm": true,
    "graphql": true,
    "ansible": true,
    "python-snippets": true,
    "rose-pine-theme": true,
  },
  "disable_ai": true,
  // "document_symbols": "on", want to use this eventually, but tree-sitter and lsp suck for python
  "wrap_guides": [80, 120],
  "cursor_blink": false,
  "buffer_font_family": "Iosevka Term",
  "vertical_scroll_margin": 8,
  "which_key": {
    "enabled": true,
  },
  "colorize_brackets": true,
  "inlay_hints": {
    "enabled": true,
  },
  "use_autoclose": false,
  "active_pane_modifiers": {
    "inactive_opacity": 0.6,
  },
  "restore_on_startup": "last_workspace",
  "theme": {
    "mode": "system",
    "light": "Rosé Pine Moon",
    "dark": "Rosé Pine",
  },
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "file_types": {
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml",
      "**/templates/**/*.yml",
      "**/helmfile.d/**/*.yaml",
      "**/helmfile.d/**/*.yml",
      "**/values*.yaml",
    ],
  },
  "format_on_save": "off",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "outline_panel": {
    "dock": "right",
  },
  "terminal": {
    "shell": {
      "program": "zsh",
    },
    "dock": "bottom",
    "cursor_shape": "block",
    "copy_on_select": true,
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "languages": {
    "YAML": {
      // yaml ls messes with helm charts
      "language_servers": ["!yaml-language-server", "..."],
    },
  },
}

// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "(EmptyPane || (Editor && vim_mode == normal) || ProjectPanel || OutlinePanel)",
    "bindings": {
      "space": null, // Disable the default action vim::WrappingRight
      "space space": "file_finder::Toggle",
      "space p": "projects::OpenRecent",
      "space r": "editor::RestartLanguageServer",
      "space t": "task::Spawn",
      "space v": "toolchain::Select",
      "space l g": [
        "task::Spawn",
        { "task_name": "lazygit", "reveal_target": "center" },
      ],
      "space k": [
        "task::Spawn",
        { "task_name": "kube", "reveal_target": "center" },
      ],
      "space c k d": ["task::Spawn", { "task_name": "deploy" }],
      "space c p v": ["task::Spawn", { "task_name": "venv" }],
      "space c p t": ["task::Spawn", { "task_name": "pytest" }],
    },
  },
  {
    "context": "(Editor || Workspace)",
    "bindings": {
      "ctrl-shift-l": "workspace::ToggleRightDock",
      "ctrl-shift-h": "workspace::ToggleLeftDock",
      "ctrl-shift-j": "workspace::ToggleBottomDock",
      "ctrl-v": "terminal::ToggleViMode",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Editor && (vim_mode == normal || vim_mod == visual)",
    "bindings": {
      // Harpoon style mark jumping
      "alt-shift-a": ["workspace::SendKeystrokes", "m shift-a"],
      "alt-shift-e": ["workspace::SendKeystrokes", "m shift-e"],
      "alt-shift-i": ["workspace::SendKeystrokes", "m shift-i"],
      "alt-shift-c": ["workspace::SendKeystrokes", "m shift-c"],
      "alt-a": ["workspace::SendKeystrokes", "` shift-a"],
      "alt-e": ["workspace::SendKeystrokes", "` shift-e"],
      "alt-i": ["workspace::SendKeystrokes", "` shift-i"],
      "alt-c": ["workspace::SendKeystrokes", "` shift-c"],

      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem",

      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "shift-x": "vim::Exchange",
      "shift-s": "vim::PushAddSurrounds",
    },
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      // mini.ai plugin behavior
      "q": "vim::MiniQuotes",
      "b": "vim::MiniBrackets",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-alt-w": "pane::CloseActiveItem",
      "ctrl-alt-h": "pane::CloseItemsToTheLeft",
      "ctrl-alt-l": "pane::CloseItemsToTheRight",
    },
  },
  {
    "context": "Dock",
    "bindings": {
      "ctrl-alt-w": "workspace::CloseActiveDock",
    },
  },
]
